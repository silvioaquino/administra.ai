// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============= USUÁRIOS E ASSINATURAS =============

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String?
  name         String?
  trialEndsAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // NOVOS CAMPOS PARA RESET DE SENHA
  resetToken       String?   @unique
  resetTokenExpiry DateTime?

  // Relacionamentos
  subscription               Subscription?
  empresas                   Empresa[]
  notasFiscais               NotaFiscal[]
  produtos                   Produto[]
  pagamentos                 Pagamento[]
  livroDiario                LivroDiario[]
  planejamentoConfig         PlanejamentoConfig[]
  planejamentoFaturamento    PlanejamentoFaturamento[]
  planejamentoAcompanhamento PlanejamentoAcompanhamento[]
  fichasTecnicas             FichaTecnica[]
  fichasItens                FichaItem[]
  provisoesFuncionarios      ProvisaoFuncionario[]
  despesasFixas              DespesaFixa[]
  despesasVariaveis          DespesaVariavel[]
  funcionarios               Funcionario[]
  taxasCartaoConfig          TaxasCartaoConfig?
  contasFinanceiras          ContaFinanceira[]
  metasFluxoCaixa            MetaFluxoCaixa[]
  fluxoCaixaDiario           FluxoCaixaDiario[]
  planoContas                PlanoContas[]
  fechamentoMensal           FechamentoMensal[]
  dreResultados              DreResultado[]
  boletos                    Boleto[]
  categorias                 Categoria[]
  caixasAbertura             CaixaAbertura[]
  caixasFechamento           CaixaFechamento[]
  vendas                     Venda[]
  vendasManuais              VendaManual[]
  retiradas                  Retirada[]
  produtosVenda              ProdutoVenda[]

  @@map("users")
}

model Subscription {
  id        String    @id @default(cuid())
  userId    String    @unique
  planId    String
  status    String // active, canceled, expired, trialing
  startDate DateTime
  endDate   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan Plan @relation(fields: [planId], references: [id])

  @@map("subscriptions")
}

model Plan {
  id            String   @id @default(cuid())
  name          String
  price         Float
  features      Json
  isActive      Boolean  @default(true)
  stripePriceId String?
  createdAt     DateTime @default(now())

  subscriptions Subscription[]

  @@map("plans")
}

model Empresa {
  id          String   @id @default(cuid())
  userId      String
  nome        String? // Nome da loja/empresa
  whatsapp    String? // WhatsApp da loja
  segmento    String? // Segmento (Restaurante, Pizzaria, etc.)
  cep         String? // CEP
  logradouro  String? // Endereço (Rua, Avenida)
  numero      String? // Número
  complemento String? // Complemento
  bairro      String? // Bairro
  cidade      String? // Cidade
  estado      String? // Estado (UF)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Relacionamentos - todos os dados da empresa
  contasFinanceiras          ContaFinanceira[]
  notasFiscais               NotaFiscal[]
  produtos                   Produto[]
  pagamentos                 Pagamento[]
  livroDiario                LivroDiario[]
  planejamentoConfig         PlanejamentoConfig[]
  planejamentoFaturamento    PlanejamentoFaturamento[]
  planejamentoAcompanhamento PlanejamentoAcompanhamento[]
  fichasTecnicas             FichaTecnica[]
  provisoesFuncionarios      ProvisaoFuncionario[]
  despesasFixas              DespesaFixa[]
  despesasVariaveis          DespesaVariavel[]
  funcionarios               Funcionario[]
  metasFluxoCaixa            MetaFluxoCaixa[]
  fluxoCaixaDiario           FluxoCaixaDiario[]
  planoContas                PlanoContas[]
  fechamentoMensal           FechamentoMensal[]
  dreResultados              DreResultado[]
  boletos                    Boleto[]
  categorias                 Categoria[]
  caixasAbertura             CaixaAbertura[]
  fichasItens                FichaItem[]
  produtosVenda              ProdutoVenda[]
  vendas                     Venda[]
  vendasManuais              VendaManual[]
  retiradas                  Retirada[]
  caixasFechamento           CaixaFechamento[]
  taxasCartaoConfig          TaxasCartaoConfig?

  @@map("empresas")
}

// ============= CONTAS FINANCEIRAS =============

model ContaFinanceira {
  id           Int      @id @default(autoincrement())
  empresaId    String   @map("empresa_id")
  userId       String   @map("user_id")
  nome         String
  tipo         String // CONTA_CORRENTE, CARTEIRA, APLICACAO, CONTA_IFOOD
  saldoInicial Decimal  @default(0) @map("saldo_inicial") @db.Decimal(10, 2)
  instituicao  String? // Banco, Fintech, etc.
  isDefault    Boolean  @default(false) @map("is_default")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  despesasFixas DespesaFixa[]

  @@unique([nome, empresaId])
  @@index([empresaId])
  @@map("contas_financeiras")
}

// ============= NOTAS FISCAIS =============

model NotaFiscal {
  id               Int      @id @default(autoincrement())
  empresaId        String
  userId           String
  chaveAcesso      String   @unique @map("chave_acesso")
  numero           Int
  serie            Int      @default(1)
  dataEmissao      DateTime @map("data_emissao")
  cnpjEmitente     String   @map("cnpj_emitente")
  nomeEmitente     String   @map("nome_emitente")
  ieEmitente       String?  @map("ie_emitente")
  enderecoEmitente String?  @map("endereco_emitente")
  valorTotal       Decimal  @map("valor_total") @db.Decimal(10, 2)
  cpfConsumidor    String?  @map("cpf_consumidor")
  createdAt        DateTime @default(now()) @map("created_at")

  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  empresa     Empresa       @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  produtos    Produto[]
  pagamentos  Pagamento[]
  livroDiario LivroDiario[]

  @@index([userId, chaveAcesso])
  @@index([dataEmissao])
  @@index([empresaId])
  @@map("notas_fiscais")
}

model Produto {
  id            Int       @id @default(autoincrement())
  empresaId     String
  userId        String
  notaFiscalId  Int?      @map("nota_fiscal_id")
  chaveAcesso   String?   @map("chave_acesso")
  codigo        String?
  descricao     String
  unidade       String?   @default("UN")
  quantidade    Decimal?  @db.Decimal(10, 3)
  valorUnitario Decimal?  @map("valor_unitario") @db.Decimal(10, 2)
  valorTotal    Decimal?  @map("valor_total") @db.Decimal(10, 2)
  fornecedor    String?
  dataCompra    DateTime? @map("data_compra")
  precoVenda    Decimal?  @default(0) @map("preco_venda") @db.Decimal(10, 2)
  createdAt     DateTime  @default(now()) @map("created_at")

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  empresa    Empresa     @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  notaFiscal NotaFiscal? @relation(fields: [notaFiscalId], references: [id], onDelete: SetNull)
  itensFicha FichaItem[]

  @@index([userId, descricao])
  @@index([empresaId])
  @@map("produtos")
}

model Pagamento {
  id             Int     @id @default(autoincrement())
  empresaId      String
  userId         String
  notaFiscalId   Int     @map("nota_fiscal_id")
  formaPagamento String  @map("forma_pagamento")
  valor          Decimal @db.Decimal(10, 2)

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  empresa    Empresa    @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  notaFiscal NotaFiscal @relation(fields: [notaFiscalId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([empresaId])
  @@map("pagamentos")
}

// ============= LIVRO DIÁRIO =============

model LivroDiario {
  id                Int      @id @default(autoincrement())
  empresaId         String
  userId            String
  data              DateTime
  conta             String
  descricao         String
  clienteFornecedor String?  @map("cliente_fornecedor")
  entrada           Decimal  @default(0) @db.Decimal(10, 2)
  saida             Decimal  @default(0) @db.Decimal(10, 2)
  tipo              String   @default("VENDA")
  notaFiscalId      Int?     @map("nota_fiscal_id")
  origemDestino     String?  @map("origem_destino")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  empresa    Empresa     @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  notaFiscal NotaFiscal? @relation(fields: [notaFiscalId], references: [id], onDelete: SetNull)
  boletos    Boleto[]

  @@index([userId, data])
  @@index([userId, conta])
  @@index([userId, tipo])
  @@index([userId, origemDestino])
  @@index([empresaId])
  @@map("livro_diario")
}

// ============= PLANEJAMENTO =============

model PlanejamentoConfig {
  id            Int      @id @default(autoincrement())
  empresaId     String
  userId        String
  tipo          String // despesas_fixas, despesas_variaveis, funcionarios
  dados         Json
  anoReferencia Int      @map("ano_referencia")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@unique([empresaId, userId, tipo, anoReferencia])
  @@index([userId, tipo, anoReferencia])
  @@index([empresaId])
  @@map("planejamento_config")
}

model PlanejamentoFaturamento {
  id               Int      @id @default(autoincrement())
  empresaId        String
  userId           String
  ano              Int
  mes              Int
  metaDiariaAlmoco Float    @default(0) @map("meta_diaria_almoco")
  metaDiariaJanta  Float    @default(0) @map("meta_diaria_janta")
  diasTrabalhados  Int      @default(26) @map("dias_trabalhados")
  lucroDesejado    Float    @default(15)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@unique([empresaId, userId, ano, mes])
  @@index([userId, ano, mes])
  @@index([empresaId])
  @@map("planejamento_faturamento")
}

model PlanejamentoAcompanhamento {
  id                Int      @id @default(autoincrement())
  empresaId         String
  userId            String
  ano               Int
  mes               Int
  faturamentoAlmoco Float    @default(0) @map("faturamento_almoco")
  faturamentoJanta  Float    @default(0) @map("faturamento_janta")
  faturamentoTotal  Float    @default(0) @map("faturamento_total")
  observacao        String?
  updatedAt         DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@unique([empresaId, userId, ano, mes])
  @@index([userId, ano, mes])
  @@index([empresaId])
  @@map("planejamento_acompanhamento")
}

// ============= FICHAS TÉCNICAS =============

model FichaTecnica {
  id                String   @id @default(cuid())
  empresaId         String
  userId            String
  nome              String
  categoria         String // Almoço, Janta
  precoVenda        Decimal  @default(0) @map("preco_venda") @db.Decimal(10, 2)
  custoTotal        Decimal  @default(0) @map("custo_total") @db.Decimal(10, 2)
  custoPorPorcao    Decimal  @default(0) @map("custo_por_porcao") @db.Decimal(10, 2)
  margem            Decimal  @default(0) @db.Decimal(5, 2)
  rendimentoPorcoes Int      @default(1) @map("rendimento_porcoes")
  ingredientes      String?  @db.Text
  modoPreparo       String?  @map("modo_preparo") @db.Text
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  empresa    Empresa     @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  fichaItems FichaItem[] // Relação inversa com FichaItem

  @@index([userId, nome])
  @@index([userId, categoria])
  @@index([empresaId])
  @@map("fichas_tecnicas")
}

model FichaItem {
  id               String   @id @default(cuid())
  empresaId        String
  userId           String
  fichaId          String   @map("ficha_id")
  produtoId        Int      @map("produto_id")
  quantidade       Float
  unidade          String?  @default("UN")
  valorUnitario    Decimal? @map("valor_unitario") @db.Decimal(10, 2)
  custo            Decimal? @db.Decimal(10, 2)
  isProdutoAcabado Boolean  @default(false) @map("is_produto_acabado")

  ficha   FichaTecnica @relation(fields: [fichaId], references: [id], onDelete: Cascade)
  produto Produto      @relation(fields: [produtoId], references: [id])
  empresa Empresa      @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([fichaId])
  @@index([produtoId])
  @@index([empresaId])
  @@map("ficha_itens")
}

// ============= DESPESAS E CONFIGURAÇÕES =============

model DespesaFixa {
  id         Int      @id @default(autoincrement())
  empresaId  String
  userId     String
  nome       String
  valor      Decimal  @db.Decimal(10, 2)
  vencimento DateTime
  contaId    Int?     @map("conta_id")
  status     String   @default("PENDENTE")
  ordem      Int      @default(0)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  empresa Empresa     @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  conta ContaFinanceira? @relation(fields: [contaId], references: [id])

  @@unique([empresaId, userId, nome])
  @@index([userId])
  @@index([empresaId])
  @@map("despesas_fixas")
}

model DespesaVariavel {
  id         Int      @id @default(autoincrement())
  empresaId  String
  userId     String
  nome       String
  percentual Float
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@unique([empresaId, userId, nome])
  @@index([userId])
  @@index([empresaId])
  @@map("despesas_variaveis")
}

model Funcionario {
  id        Int      @id @default(autoincrement())
  empresaId String
  userId    String
  nome      String
  salario   Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@unique([empresaId, userId, nome])
  @@index([userId])
  @@index([empresaId])
  @@map("funcionarios")
}

model TaxasCartaoConfig {
  id        Int      @id @default(autoincrement())
  empresaId String   @unique
  userId    String   @unique
  config    Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@map("taxas_cartao_config")
}

model ProvisaoFuncionario {
  id              Int      @id @default(autoincrement())
  empresaId       String
  userId          String
  ano             Int
  provisao        String
  funcionarioNome String   @map("funcionario_nome")
  ativo           Boolean  @default(true)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@unique([empresaId, userId, ano, provisao, funcionarioNome])
  @@index([userId, ano, provisao])
  @@index([empresaId])
  @@map("provisoes_funcionarios")
}

// ============= METAS E FLUXO DE CAIXA =============

model MetaFluxoCaixa {
  id                    Int      @id @default(autoincrement())
  empresaId             String   @map("empresa_id")
  userId                String   @map("user_id")
  ano                   Int
  mes                   Int
  metaFaturamentoDiaria Decimal  @default(0) @map("meta_faturamento_diaria") @db.Decimal(10, 2)
  metaDespesasDiaria    Decimal  @default(0) @map("meta_despesas_diaria") @db.Decimal(10, 2)
  metaLucroPercentual   Float    @default(20) @map("meta_lucro_percentual")
  diasUteis             Int      @default(30) @map("dias_uteis")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@unique([empresaId, userId, ano, mes])
  @@index([userId, ano, mes])
  @@index([empresaId])
  @@map("metas_fluxo_caixa")
}

model FluxoCaixaDiario {
  id                   Int      @id @default(autoincrement())
  empresaId            String   @map("empresa_id")
  userId               String   @map("user_id")
  data                 DateTime
  faturamentoRealizado Decimal  @default(0) @map("faturamento_realizado") @db.Decimal(10, 2)
  despesasRealizadas   Decimal  @default(0) @map("despesas_realizadas") @db.Decimal(10, 2)
  lucroRealizado       Decimal  @default(0) @map("lucro_realizado") @db.Decimal(10, 2)
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@unique([empresaId, userId, data])
  @@index([userId, data])
  @@index([empresaId])
  @@map("fluxo_caixa_diario")
}

// ============= PLANO DE CONTAS GERENCIAL =============

model PlanoContas {
  id        Int      @id @default(autoincrement())
  empresaId String   @map("empresa_id")
  userId    String   @map("user_id")
  codigo    String // Ex: 3.1.1, 4.1.1, etc.
  nome      String
  tipo      String // RECEITA, CUSTO, DESPESA
  grupo     String // RECEITA_BRUTA, CMV, DESPESAS_OPERACIONAIS, RESULTADO
  ordem     Int      @default(0)
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@unique([empresaId, userId, codigo])
  @@index([userId, tipo, grupo])
  @@index([empresaId])
  @@map("plano_contas")
}

model FechamentoMensal {
  id             Int       @id @default(autoincrement())
  empresaId      String    @map("empresa_id")
  userId         String    @map("user_id")
  ano            Int
  mes            Int
  status         String    @default("ABERTO") // ABERTO, FECHADO, REABERTO
  dataFechamento DateTime? @map("data_fechamento")
  observacao     String?
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@unique([empresaId, userId, ano, mes])
  @@index([userId, ano, mes, status])
  @@index([empresaId])
  @@map("fechamento_mensal")
}

model DreResultado {
  id         Int      @id @default(autoincrement())
  empresaId  String   @map("empresa_id")
  userId     String   @map("user_id")
  ano        Int
  mes        Int
  linha      String // RECEITA_BRUTA, CMV, LUCRO_BRUTO, etc.
  descricao  String
  valor      Decimal  @db.Decimal(15, 2)
  percentual Float
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@unique([empresaId, userId, ano, mes, linha])
  @@index([userId, ano, mes])
  @@index([empresaId])
  @@map("dre_resultados")
}

// ============= CAIXA DIÁRIO =============

model CaixaAbertura {
  id            String           @id @default(uuid())
  empresaId     String           @map("empresa_id")
  userId        String           @map("user_id")
  dataAbertura  DateTime         @default(now())
  valorInicial  Float
  observacao    String?
  status        String           @default("ABERTO")
  vendas        Venda[]
  vendasManuais VendaManual[]
  retiradas     Retirada[]
  fechamento    CaixaFechamento?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([dataAbertura])
  @@index([empresaId])
  @@map("caixa_abertura")
}

model Venda {
  id              String        @id @default(uuid())
  empresaId       String      @map("empresa_id")
  userId          String      @map("user_id")
  dataVenda       DateTime      @default(now())
  dadosPedido     Json
  tipoPagamento   String        @default("PENDENTE")
  valorTotal      Float
  manual          Boolean       @default(false)
  caixaAbertura   CaixaAbertura @relation(fields: [caixaAberturaId], references: [id])
  caixaAberturaId String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Informações do cliente
  nomeCliente     String?
  telefoneCliente String?
  tipoPedido      String?
  endereco        String?

  // Controle de duplicatas
  numeroPedido String? @unique

  // Produtos da venda
  produtos ProdutoVenda[]

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@index([dataVenda])
  @@index([caixaAberturaId])
  @@index([tipoPagamento])
  @@index([nomeCliente])
  @@index([tipoPedido])
  @@index([numeroPedido])
  @@index([empresaId])
  @@map("vendas")
}

model ProdutoVenda {
  id         String  @id @default(uuid())
  empresaId  String  @map("empresa_id")
  userId     String  @map("user_id")
  vendaId    String
  nome       String
  quantidade Int
  valor      Float
  adicionais Json? // Array de adicionais
  observacao String?

  venda     Venda    @relation(fields: [vendaId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  empresa   Empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([vendaId])
  @@index([nome])
  @@index([empresaId])
  @@map("produto_venda")
}

model VendaManual {
  id              String        @id @default(uuid())
  empresaId       String      @map("empresa_id")
  userId          String      @map("user_id")
  dataVenda       DateTime      @default(now())
  tipoPagamento   String
  valor           Float
  descricao       String?
  caixaAbertura   CaixaAbertura @relation(fields: [caixaAberturaId], references: [id])
  caixaAberturaId String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@index([caixaAberturaId])
  @@index([tipoPagamento])
  @@index([empresaId])
  @@map("vendas_manuais")
}

model Retirada {
  id              String        @id @default(uuid())
  empresaId       String      @map("empresa_id")
  userId          String      @map("user_id")
  dataRetirada    DateTime      @default(now())
  valor           Float
  observacao      String?
  caixaAbertura   CaixaAbertura @relation(fields: [caixaAberturaId], references: [id])
  caixaAberturaId String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@index([caixaAberturaId])
  @@map("retiradas")
}

model CaixaFechamento {
  id              String        @id @default(uuid())
  empresaId       String      @map("empresa_id")
  userId          String      @map("user_id")
  dataFechamento  DateTime      @default(now())
  valorAbertura   Float
  totalVendas     Float
  retiradas       Float
  saldoFinal      Float
  observacoes     String?
  caixaAbertura   CaixaAbertura @relation(fields: [caixaAberturaId], references: [id])
  caixaAberturaId String        @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@index([empresaId])
  @@index([userId])
  @@map("caixa_fechamento")
}


model Boleto {
  id              Int       @id @default(autoincrement())
  empresaId       String    @map("empresa_id")
  userId          String    @map("user_id")
  lancamentoId    Int?      @map("lancamento_id")
  codigoBarras    String    @map("codigo_barras")
  numeroDocumento String    @map("numero_documento")
  valor           Decimal   @db.Decimal(10, 2)
  dataVencimento  DateTime  @map("data_vencimento")
  dataPagamento   DateTime? @map("data_pagamento")
  status          String    @default("PENDENTE") // PENDENTE, PAGO, VENCIDO, CANCELADO
  observacao      String?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relacionamentos
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  empresa    Empresa      @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  lancamento LivroDiario? @relation(fields: [lancamentoId], references: [id])

  @@unique([empresaId, numeroDocumento])
  @@index([userId, status])
  @@index([dataVencimento])
  @@index([lancamentoId])
  @@index([empresaId])
  @@map("boletos")
}

// ============= CATEGORIAS =============

model Categoria {
  id        Int      @id @default(autoincrement())
  empresaId String   @map("empresa_id")
  userId    String?  @map("user_id")
  codigo    String // Ex: 3.1.1, 4.1.1, etc.
  nome      String
  nivel     Int // 0=header, 1=categoria, 2=subcategoria, 3=item
  tipo      String // receita, despesa
  isHeader  Boolean  @default(false) @map("is_header")
  parentId  Int?     @map("parent_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)
  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@unique([empresaId, codigo])
  @@index([userId, tipo, nivel])
  @@index([empresaId])
  @@map("categorias")
}